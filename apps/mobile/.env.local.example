# Anywhere Mobile — Local Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must NEVER be committed.

# Local API Gateway (dev)
API_BASE_URL=http://localhost:3001

# Mapbox — use your PUBLIC token (pk.xxx)
MAPBOX_PUBLIC_TOKEN=pk.REPLACE_WITH_YOUR_MAPBOX_PUBLIC_TOKEN

# Stripe — use your PUBLISHABLE key (pk_test_xxx or pk_live_xxx)
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY
