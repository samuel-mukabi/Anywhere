MONGODB_URI=mongodb+srv://samuel:Vuv9PXXyaboxQDHA@cluster0.kvjeivf.mongodb.net/?appName=Cluster0

# --- Redis / Upstash (Cache + BullMQ) ------------------------------------
# See ADR-004: Redis (Upstash) for caching + BullMQ
UPSTASH_REDIS_REST_URL=https://<db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# --- Maps -----------------------------------------------------------------
# See ADR-005: Mapbox GL JS
# NEXT_PUBLIC_ token must be URL-restricted to *.anywhere.travel in Mapbox dashboard
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
MAPBOX_SECRET_TOKEN=sk.eyJ1...      # Server-only — Static Images API

# --- Flight APIs ----------------------------------------------------------
# See docs/external-api-dependencies.md — Amadeus rate limits are strict
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
RAPIDAPI_SKYSCANNER_KEY=            # Fallback / background worker only

# --- Cost of Living -------------------------------------------------------
# Numbeo: ~100 calls/day on basic — ONLY used in nightly BullMQ cron job
NUMBEO_API_KEY=

# --- Weather / Climate ----------------------------------------------------
# OpenWeatherMap: 1M calls/month free — used in hourly BullMQ cron job
OPENWEATHERMAP_API_KEY=

# --- Payments (Stripe) ---------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...       # Server-only
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- Notifications --------------------------------------------------------
RESEND_API_KEY=re_...               # Transactional email
EXPO_ACCESS_TOKEN=                  # Mobile push notifications
