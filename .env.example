NEXT_PUBLIC_SUPABASE_URL=https://jtdjyfzzzhdwafraczyp.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_OoQMPr-KwZxSB1aQBx66fA_aBx__jKB
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp0ZGp5Znp6emhkd2FmcmFjenlwIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NjQzNDUyNCwiZXhwIjoyMDkyMDEwNTI0fQ.CuvY2X18pXO2Eo_GA9YxbaWirCGu85DBzHo4qnYsxbk          # Server-only — bypasses RLS, never expose to client
