# =============================================================================
# Anywhere — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# See docs/external-api-dependencies.md for rate limits and caching strategy.
# =============================================================================

# --- App ------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Next.js Auth (if using NextAuth alongside Supabase) ------------------
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=

# --- Supabase (PostgreSQL + Auth) -----------------------------------------
# See ADR-003: PostgreSQL (Supabase) for transactional data
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key# Server-only — bypasses RLS, never expose to client
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# Supabase OAuth providers
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
SUPABASE_AUTH_APPLE_CLIENT_ID=
SUPABASE_AUTH_APPLE_SECRET=

# --- MongoDB Atlas (Trip Documents) ---------------------------------------
# See ADR-003: MongoDB Atlas for trip documents
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Anywhere

# --- Redis / Upstash (Cache + BullMQ) ------------------------------------
# See ADR-004: Redis (Upstash) for caching + BullMQ
UPSTASH_REDIS_REST_URL=https://your-redis-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- Maps -----------------------------------------------------------------
# See ADR-005: Mapbox GL JS
# NEXT_PUBLIC_ token must be URL-restricted to *.anywhere.travel in Mapbox dashboard
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token
MAPBOX_SECRET_TOKEN=your-mapbox-secret-token# Server-only — Static Images API
NEXT_PUBLIC_MAPBOX_STYLE_URL=

# --- Flight APIs ----------------------------------------------------------
# See docs/external-api-dependencies.md
TRAVELPAYOUTS_TOKEN=                # Travel Payouts Data API token

RAPIDAPI_SKYSCANNER_KEY=            # Fallback / background worker only
DUFFEL_TEST_TOKEN=                  # Duffel sandbox token
DUFFEL_LIVE_TOKEN=                  # Duffel production token
GEODB_RAPIDAPI_KEY=                 # GeoDB RapidAPI key

# --- Cost of Living & Quality ---------------------------------------------
# WhereNext API: Free CoL provider (no API key required)

# --- Weather / Climate (Open-Meteo — free, no API key) -------------------
# Historical archive endpoint: https://archive-api.open-meteo.com
# Climate profiles recomputed quarterly by the workers cron job.
# OPENWEATHERMAP_API_KEY=  # removed; using Open-Meteo instead

# --- Payments (Stripe) ---------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...       # Server-only
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- Core infra aliases used across deploy targets ------------------------
REDIS_URL=redis://localhost:6379

# --- Notifications --------------------------------------------------------
RESEND_API_KEY=re_...               # Transactional email
EXPO_ACCESS_TOKEN=                  # Mobile push notifications

# --- Travel Risk Live API -------------------------------------------------
TRAVEL_RISK_API_KEY=demo-key-travel-risk-2026
