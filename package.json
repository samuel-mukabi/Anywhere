{
  "name": "anywhere-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:mobile": "turbo run dev --filter=@repo/mobile",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "prepare": "husky",
    "postinstall": "node scripts/patch-expo-router.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@testing-library/react-native": "^13.3.3",
    "husky": "^9.0.0",
    "react-native": "^0.81.5",
    "react-test-renderer": "^19.1.0",
    "turbo": "^2.0.0"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-reanimated": "3.16.2",
    "@rnmapbox/maps": "10.2.10",
    "zod": "^3.25.76"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
